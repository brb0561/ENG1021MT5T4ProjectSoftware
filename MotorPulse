import org.firmata4j.Pin;
import org.firmata4j.firmata.FirmataDevice;

public class MotorPulse {
    public static void main(String[] args) throws Exception {

        FirmataDevice board = new FirmataDevice("COM3");
        board.start();
        board.ensureInitializationIsDone();

        Pin motor = board.getPin(5);
        motor.setMode(Pin.Mode.OUTPUT);

        while (true) {
            // RUN
            motor.setValue(1);
            Thread.sleep(1000);   // adjust this (how long it spins)

            // STOP
            motor.setValue(0);
            Thread.sleep(800);   // adjust this (pause time)
        }
    }
}
